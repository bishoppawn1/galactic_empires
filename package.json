{
  "name": "galactic-empires",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.js",
    "build": "tsc -b && vite build --config vite.config.js",
    "test": "vitest run",
    "test:rules": "vitest run src/game.test.ts",
    "test:ui": "vitest run src/App.test.tsx",
    "test:watch": "vitest",
    "check": "npm run test && npm run build",
    "preview": "vite preview --config vite.config.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "peerjs": "^1.5.5",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "jsdom": "latest",
    "vitest": "latest"
  }
}
